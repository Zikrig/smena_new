# Скопируйте в .env и заполните значения.

# Обязательно: токен от @BotFather
BOT_TOKEN=

# Админы бота (личка /admin): Telegram user id через запятую, без пробелов
# ADMIN_IDS=123456789,987654321

# SQLite (по умолчанию — guard_bot.db рядом с приложением)
# В Docker через compose обычно: /app/data/guard_bot.db
# DATABASE_PATH=

# Google Sheets (необязательно; без них бот только шлёт в Telegram)
# GOOGLE_SHEETS_SPREADSHEET_ID=
# Путь к JSON ключу сервисного аккаунта
# GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json

# Часовой пояс процесса (для дат в логах/подписях, если используете TZ в коде)
# TZ=Europe/Moscow
